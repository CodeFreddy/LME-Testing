# frozen_string_literal: true

require 'cucumber'
require 'cucumber/rake/task'
require 'rspec/core/rake_task'

# Load environment
load 'features/support/env.rb'

namespace :test do
  desc 'Run all tests'
  Cucumber::Rake::Task.new(:all) do |t|
    t.cucumber_opts = '--profile default'
  end

  desc 'Run API tests only'
  Cucumber::Rake::Task.new(:api) do |t|
    t.cucumber_opts = '--profile api'
  end

  desc 'Run smoke tests only'
  Cucumber::Rake::Task.new(:smoke) do |t|
    t.cucumber_opts = '--profile smoke'
  end

  desc 'Run regression tests'
  Cucumber::Rake::Task.new(:regression) do |t|
    t.cucumber_opts = '--profile regression'
  end
end

namespace :ci do
  desc 'Run tests with JUnit output for CI'
  Cucumber::Rake::Task.new(:cucumber) do |t|
    t.cucumber_opts = '--profile json'
    ENV['GENERATE_JUNIT'] = 'true'
  end
end

namespace :db do
  desc 'Seed test data'
  task :seed do
    puts 'Seeding test data...'
    # TODO: Implement seed data
    puts 'Done.'
  end

  desc 'Reset test database'
  task :reset do
    puts 'Resetting test database...'
    # TODO: Implement database reset
    puts 'Done.'
  end
end

task default: 'test:all'

desc 'Run tests with coverage'
task :coverage do
  ENV['COVERAGE'] = 'true'
  Rake::Task['test:all'].invoke
end
