{
    "output_root": "runs",
    "providers": {
        "stub": {
            "type": "stub",
            "model": "stub-model",
            "base_url": "http://stub",
            "api_key": "stub"
        },
        "maker_glm": {
            "type": "openai_compatible",
            "api_format": "openai_chat_completions",
            "base_url": "https://coding.dashscope.aliyuncs.com/v1",
            "model": "glm-5",
            "api_key_env": "API_KEY",
            "timeout_seconds": 300,
            "temperature": 0.1,
            "max_output_tokens": 8000
        },
        "checker_minimax": {
            "type": "openai_compatible",
            "api_format": "openai_chat_completions",
            "base_url": "https://coding.dashscope.aliyuncs.com/v1",
            "model": "MiniMax-M2.5",
            "api_key_env": "API_KEY",
            "timeout_seconds": 300,
            "temperature": 0.0,
            "max_output_tokens": 6000
        },
        "bdd_qwen": {
            "type": "openai_compatible",
            "api_format": "openai_chat_completions",
            "base_url": "https://coding.dashscope.aliyuncs.com/v1",
            "model": "qwen3.6-plus",
            "api_key_env": "API_KEY",
            "timeout_seconds": 300,
            "temperature": 0.0,
            "max_output_tokens": 16000
        },
        "scripts_kimi": {
            "type": "openai_compatible",
            "api_format": "openai_chat_completions",
            "base_url": "https://coding.dashscope.aliyuncs.com/v1",
            "model": "kimi-k2.5",
            "api_key_env": "API_KEY",
            "timeout_seconds": 300,
            "temperature": 0.0,
            "max_output_tokens": 12000
        }
    },
    "roles": {
        "maker": "maker_glm",
        "checker": "checker_minimax",
        "bdd": "bdd_qwen",
        "scripts": "scripts_kimi",
        "planner": "maker_glm"
    },
    "maker_defaults": {
        "temperature": 0.1,
        "max_output_tokens": 8000,
        "timeout_seconds": 300
    },
    "checker_defaults": {
        "temperature": 0.0,
        "max_output_tokens": 6000,
        "timeout_seconds": 300
    }
}
