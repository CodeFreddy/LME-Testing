      "timeout_seconds": 300,
      "max_retries": 3,
      "retry_backoff_seconds": 2.0,
      "temperature": 0.0,
      "max_output_tokens": 6000
    }
  },
  "roles": {
    "maker": "maker_glm",
    "checker": "checker_minimax"
  },
  "maker_defaults": {
    "temperature": 0.1,
    "max_output_tokens": 8000,
    "timeout_seconds": 300
