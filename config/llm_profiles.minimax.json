{
    "output_root": "runs",
    "providers": {
        "minimax": {
            "type": "openai_compatible",
            "api_format": "openai_chat_completions",
            "base_url": "https://api.minimax.chat/v1",
            "model": "MiniMax-M2.7",
            "api_key_env": "ANTHROPIC_AUTH_TOKEN",
            "timeout_seconds": 300,
            "temperature": 0.1,
            "max_output_tokens": 8000
        }
    },
    "roles": {
        "maker": "minimax",
        "checker": "minimax",
        "planner": "minimax"
    },
    "maker_defaults": {
        "temperature": 0.1,
        "max_output_tokens": 8000,
        "timeout_seconds": 300
    },
    "checker_defaults": {
        "temperature": 0.0,
        "max_output_tokens": 6000,
        "timeout_seconds": 300
    }
}
